--- a/C/AesHwStub.c
+++ b/C/AesHwStub.c
@@ -0,0 +1,39 @@
+/* AesHwStub.c -- stubs for HW AES symbols
+   OpenHarmony cross build may compile out AesOpt.o but some objects can still
+   reference AesCbc_*_HW symbols. Provide safe software fallbacks so lib7z.so
+   has no unresolved AES HW symbols at load time.
+
+   This file is Public Domain in spirit (same as upstream style). */
+
+#include "Precomp.h"
+
+#include "Aes.h"
+
+/* HW AES stubs: fallback to software implementations */
+void MY_FAST_CALL AesCbc_Encode_HW(UInt32 *ivAes, Byte *data, size_t numBlocks)
+{
+  AesCbc_Encode(ivAes, data, numBlocks);
+}
+
+void MY_FAST_CALL AesCbc_Decode_HW(UInt32 *ivAes, Byte *data, size_t numBlocks)
+{
+  AesCbc_Decode(ivAes, data, numBlocks);
+}
+
+void MY_FAST_CALL AesCtr_Code_HW(UInt32 *ivAes, Byte *data, size_t numBlocks)
+{
+  AesCtr_Code(ivAes, data, numBlocks);
+}
+
+/* 256-bit optimized variants: fallback to the same software path */
+void MY_FAST_CALL AesCbc_Decode_HW_256(UInt32 *ivAes, Byte *data, size_t numBlocks)
+{
+  AesCbc_Decode(ivAes, data, numBlocks);
+}
+
+void MY_FAST_CALL AesCtr_Code_HW_256(UInt32 *ivAes, Byte *data, size_t numBlocks)
+{
+  AesCtr_Code(ivAes, data, numBlocks);
+}
+
+
